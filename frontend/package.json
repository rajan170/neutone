{
  "name": "neutone",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "node -r dotenv/config debug-env.js && bun run next build",
    "build:cf": "node -r dotenv/config debug-env.js && next build --turbo",
    "check": "bun run next lint && bun run tsc --noEmit",
    "db:generate": "bun run prisma migrate dev",
    "db:migrate": "bun run prisma migrate deploy",
    "db:push": "bun run prisma db push",
    "db:studio": "bun run prisma studio",
    "dev": "bun run next dev --turbo",
    "polar-webhooks": "bun run ngrok http 3000",
    "format:check": "bun run prettier --check \"**/*.{ts,tsx,js,jsx,mdx}\" --cache",
    "format:write": "bun run prettier --write \"**/*.{ts,tsx,js,jsx,mdx}\" --cache",
    "postinstall": "bun run prisma generate",
    "lint": "bun run next lint",
    "lint:fix": "bun run next lint --fix",
    "preview": "bun run next build && bun run next start",
    "start": "bun run next start",
    "typecheck": "bun run tsc --noEmit",
    "pages:build": "bun run build",
    "cf:typegen": "bun run wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.10.0",
    "@aws-sdk/client-s3": "^3.873.0",
    "@aws-sdk/s3-request-presigner": "^3.873.0",
    "@daveyplate/better-auth-ui": "^3.0.2",
    "@geist-ui/core": "^2.3.8",
    "@geist-ui/icons": "^1.0.2",
    "@hcaptcha/react-hcaptcha": "^1.12.1",
    "@hookform/resolvers": "^5.2.0",
    "@marsidev/react-turnstile": "^1.3.0",
    "@polar-sh/better-auth": "^1.1.0",
    "@polar-sh/sdk": "^0.34.14",
    "@prisma/client": "^6.14.0",
    "@radix-ui/react-avatar": "^1.1.0",
    "@radix-ui/react-checkbox": "^1.1.0",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.7",
    "@radix-ui/react-select": "^2.1.0",
    "@radix-ui/react-separator": "^1.1.7",
    "@radix-ui/react-slider": "^1.3.6",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@t3-oss/env-nextjs": "^0.12.0",
    "better-auth": "1.3.8",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^16.4.5",
    "framer-motion": "^12.23.12",
    "global": "^4.4.0",
    "inngest": "^3.40.1",
    "inngest-cli": "^1.11.5",
    "input-otp": "^1.4.2",
    "lucide-react": "^0.539.0",
    "motion": "^12.23.12",
    "next": "^15.5.2",
    "next-themes": "^0.4.6",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.52.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.3.1",
    "vaul": "^1.1.2",
    "zod": "^3.24.2",
    "zustand": "^5.0.8"
  },
  "devDependencies": {
    "@types/node": "^20.14.10",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.5.6",
    "prettier": "^3.5.3",
    "prisma": "^6.14.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.8.2"
  },
  "ct3aMetadata": {
    "initVersion": "7.39.3"
  }
}
